# Base URL pública de la app
NEXT_PUBLIC_APP_URL=https://margenreal.io

# PostgreSQL — conexión principal
DATABASE_URL=postgresql://user:password@host:5432/margenreal

# JWT — secreto para firmar tokens de acceso y activación
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio

# Lemon Squeezy — webhook
LS_WEBHOOK_SECRET=whsec_...

# Lemon Squeezy — IDs de variantes de producto (para mapear plan en webhook)
NEXT_PUBLIC_LS_VARIANT_STARTER=123456
NEXT_PUBLIC_LS_VARIANT_PRO=789012

# Resend — email transaccional (activación de cuenta)
RESEND_API_KEY=re_...

# PostHog — analytics (opcional en desarrollo)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
